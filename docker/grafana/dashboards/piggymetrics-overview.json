{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "PiggyMetrics — Resilience4j & JVM",
  "uid": "piggymetrics-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_info, application)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Circuit breaker state",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{application=~\"$application\"}",
          "legendFormat": "{{application}} {{name}} {{state}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Circuit breaker call rate (by kind)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (application, name, kind) (rate(resilience4j_circuitbreaker_calls_seconds_count{application=~\"$application\"}[1m]))",
          "legendFormat": "{{application}} {{name}} {{kind}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP server request rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$application\"}[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM heap used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{application=~\"$application\", area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Process CPU usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "process_cpu_usage{application=~\"$application\"}",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
